<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel Respaldo</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #0f172a;
            color: #f8fafc;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        /* Proporção Estrita 4:3 */
        .window-container {
            width: 800px;
            height: 600px;
            background-color: #1e293b;
            border-radius: 12px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.3), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            border: 1px solid #334155;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* Barra de Topo Superior */
        .top-bar {
            height: 50px;
            background-color: #0f172a;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 20px;
            border-bottom: 1px solid #334155;
        }

        .brand {
            font-size: 18px;
            font-weight: 700;
            letter-spacing: 0.5px;
            color: #38bdf8;
        }

        .system-status {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: #94a3b8;
        }

        .status-indicator {
            width: 8px;
            height: 8px;
            background-color: #10b981;
            border-radius: 50%;
            box-shadow: 0 0 8px #10b981;
        }

        /* Área de Conteúdo Principal */
        .main-content {
            flex: 1;
            display: flex;
            overflow: hidden;
        }

        /* Menu Lateral (Sidebar) */
        .sidebar {
            width: 200px;
            background-color: #111827;
            padding: 20px 10px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            border-right: 1px solid #334155;
        }

        .nav-button {
            width: 100%;
            padding: 12px 15px;
            background: transparent;
            border: none;
            color: #94a3b8;
            text-align: left;
            font-size: 14px;
            font-weight: 600;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .nav-button:hover, .nav-button.active {
            background-color: #38bdf8;
            color: #0f172a;
        }

        /* Painel de Controle Direito */
        .dashboard-view {
            flex: 1;
            padding: 25px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            overflow-y: auto;
        }

        .section-title {
            font-size: 20px;
            font-weight: 600;
            color: #f1f5f9;
            margin-bottom: 5px;
        }

        /* Grid de Cards de Estatísticas */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
        }

        .card {
            background-color: #1e293b;
            border: 1px solid #334155;
            border-radius: 8px;
            padding: 15px;
        }

        .card-label {
            font-size: 12px;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .card-value {
            font-size: 24px;
            font-weight: 700;
            color: #f8fafc;
            margin-top: 5px;
        }

        /* Controles e Toggles */
        .control-group {
            background-color: #111827;
            border: 1px solid #334155;
            border-radius: 8px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .control-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .control-label {
            font-size: 14px;
            font-weight: 500;
        }

        /* Botão Switch Estilizado */
        .switch {
            position: relative;
            display: inline-block;
            width: 44px;
            height: 24px;
        }

        .switch input { 
            opacity: 0;
            width: 0;
            height: 0;
        }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #334155;
            transition: .3s;
            border-radius: 24px;
        }

        .slider:before {
            position: absolute;
            content: "";
            height: 16px;
            width: 16px;
            left: 4px;
            bottom: 4px;
            background-color: white;
            transition: .3s;
            border-radius: 50%;
        }

        input:checked + .slider {
            background-color: #38bdf8;
        }

        input:checked + .slider:before {
            transform: translateX(20px);
        }

        /* Rodapé interno */
        .footer-bar {
            height: 35px;
            background-color: #0f172a;
            border-top: 1px solid #334155;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 11px;
            color: #64748b;
        }
    </style>
</head>
<body>

    <div class="window-container">
        
        <header class="top-bar">
            <div class="brand">RESPALDO</div>
            <div class="system-status">
                <span class="status-indicator"></span>
                <span>Sistema Operacional</span>
            </div>
        </header>

        <div class="main-content">
            
            <aside class="sidebar">
                <button class="nav-button active">Visão Geral</button>
                <button class="nav-button">Configurações</button>
                <button class="nav-button">Segurança</button>
                <button class="nav-button">Logs</button>
            </aside>

            <main class="dashboard-view">
                <div>
                    <h2 class="section-title">Monitoramento de Ativos</h2>
                    <p style="color: #94a3b8; font-size: 14px;">Gerenciamento e diagnóstico em tempo real.</p>
                </div>

                <section class="stats-grid">
                    <div class="card">
                        <div class="card-label">Latência de Rede</div>
                        <div class="card-value">14 ms</div>
                    </div>
                    <div class="card">
                        <div class="card-label">Uso de Memória</div>
                        <div class="card-value">32.4 %</div>
                    </div>
                </section>

                <section class="control-group">
                    <div class="control-item">
                        <span class="control-label">Sincronização Automática</span>
                        <label class="switch">
                            <input type="checkbox" checked>
                            <span class="slider"></span>
                        </label>
                    </div>
                    <div class="control-item">
                        <span class="control-label">Aceleração de Hardware</span>
                        <label class="switch">
                            <input type="checkbox">
                            <span class="slider"></span>
                        </label>
                    </div>
                    <div class="control-item">
                        <span class="control-label">Otimização de Renderização</span>
                        <label class="switch">
                            <input type="checkbox" checked>
                            <span class="slider"></span>
                        </label>
                    </div>
                </section>
            </main>
        </div>

        <footer class="footer-bar">
            &copy; 2026 Respaldo Control Panel — Todos os direitos reservados.
        </footer>
    </div>

</body>
</html>
